# Copy to .env.local (gitignored) and fill in real credentials.
# .env.example documents only the variable names — no secrets.

# ── bar_history backend (TASK-14) ──────────────────────────────────────────
# sqlite (default)  — current behaviour, writes/reads trades.db locally
# dual              — writes to both SQLite and Postgres, reads SQLite
# postgres          — writes/reads Postgres only (cutover target)
BAR_HISTORY_BACKEND=sqlite

# Optional: override the SQLite path (defaults to trades.db in the cwd).
# BAR_HISTORY_SQLITE_PATH=trades.db

# ── MetaTrader / symbols ────────────────────────────────────────────────────
# Keep LIVE_ORDERS=0 until the terminal path and tradable contract are
# explicitly confirmed for the supervised session.
MT5_PATH=E:\MetaTradersWSL\wdowin\pairtrading\terminal64.exe
MT5_PORTABLE=true

# Data symbols can remain continuous for bars/indicators.
SYMBOL_A=WIN$N
SYMBOL_B=WDO$N
DI_SYMBOL=DI1$N

# AUTO parses the current tradable WIN contract from symbol_info(WIN$N),
# e.g. "IBOVESPA MINI - Por Liquidez (WINM26) - Sem Ajustes".
LIVE_SYMBOL_WIN=AUTO
LIVE_ORDERS=0
# ALLOW_CONTINUOUS_LIVE_SYMBOL=0

# ── Postgres / TimescaleDB connection ──────────────────────────────────────
# Required when BAR_HISTORY_BACKEND is `dual` or `postgres`.
# Format: postgresql://user:password@host:port/database
# Prefer ~/.pgpass for the password and keep this URI password-less in
# .env.local on shared hosts.
# PG_URI=postgresql://pairtrading@localhost:5432/pairtrading

# ── Postgres for opt-in integration tests ──────────────────────────────────
# Tests under tests/test_bar_history*.py and
# tests/test_backfill_bar_history_indicators.py call pytest.skip() when this
# is unset, so the default `pytest tests/` run stays SQLite-only.
# PG_TEST_URI=postgresql://pairtrading@localhost:5432/pairtrading_test
